{"id":"tooluse_PYjMkfb9UeOYHJfDjhuviw-result","timestamp":"2026-07-18T16:15:45.206Z","payload":{"type":"tool_result","toolCallId":"tooluse_PYjMkfb9UeOYHJfDjhuviw","content":"<file name=\"C:\\Users\\Ved\\Desktop\\project\\document-copilot\\backend\\tests\\test_retrieval_integration.py\" language=\"python\" >\n<content>\n\"\"\"Integration tests for end-to-end hybrid retrieval against a real database.\n\nThese tests require:\n- Active Supabase connection (DATABASE_URL in backend/.env)\n- Ingested corpus (10-Ks for AAPL, MSFT, NVDA, AMZN, GOOGL)\n- OpenAI API key with available quota (OPENAI_API_KEY in backend/.env)\n\nRun with: pytest -m integration tests/test_retrieval_integration.py -v\n\nOn Windows the SelectorEventLoop fixture in conftest.py ensures psycopg async\nworks correctly (psycopg is incompatible with ProactorEventLoop).\n\"\"\"\nfrom __future__ import annotations\n\nimport pytest\nimport pytest_asyncio\n\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom app.config import settings\nfrom app.database.session import _SessionFactory\nfrom retrieval.retriever import search_hybrid\n\n\n# ---------------------------------------------------------------------------\n# Fixtures\n# ---------------------------------------------------------------------------\n\n@pytest_asyncio.fixture\nasync def db_session() -> AsyncSession:\n    \"\"\"Open a real async DB session for the duration of one test.\"\"\"\n    async with _SessionFactory() as session:\n        yield session\n\n\n@pytest_asyncio.fixture\ndef openai_client():\n    from openai import AsyncOpenAI\n    return AsyncOpenAI(api_key=settings.openai_api_key)\n\n\nasync def _embed(client, text: str) -> list[float]:\n    \"\"\"Embed a single string; skips the test on quota / auth errors.\"\"\"\n    import openai\n    try:\n        response = await client.embeddings.create(\n            input=[text],\n            model=settings.openai_embedding_model,\n        )\n        return response.data[0].embedding\n    except openai.RateLimitError as exc:\n        pytest.skip(f\"OpenAI quota exceeded — skipping embedding-dependent test: {exc}\")\n    except openai.AuthenticationError as exc:\n        pytest.skip(f\"OpenAI auth failed — skipping embedding-dependent test: {exc}\")\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\ndef _assert_valid_passage(p) -> None:\n    \"\"\"Assert a RetrievedPassage has the expected non-empty fields.\"\"\"\n    import uuid\n    assert isinstance(p.chunk_id, uuid.UUID), \"chunk_id must be a UUID\"\n    assert isinstance(p.document_id, uuid.UUID), \"document_id must be a UUID\"\n    assert isinstance(p.text, str) and len(p.text) > 0, \"text must be non-empty\"\n    assert isinstance(p.rank, int) and p.rank >= 1, \"rank must be a positive int\"\n\n\n# ---------------------------------------------------------------------------\n# Tests\n# ---------------------------------------------------------------------------\n\n@pytest.mark.integration\n@pytest.mark.asyncio\nasync def test_fulltext_only_returns_passages(db_session):\n    \"\"\"Hybrid search without an embed_vector falls back to full-text only and\n    still returns ranked passages for a query known to be in the corpus.\"\"\"\n    from sqlalchemy import text as sa_text\n    count = (await db_session.execute(sa_text(\"SELECT COUNT(*) FROM document_chunks\"))).scalar()\n    if not count:\n        pytest.skip(\"Corpus not ingested — run the ingest pipeline first\")\n\n    result = await search_hybrid(\n        session=db_session,\n        query=\"revenue\",\n        embed_vector=None,\n        k=5,\n        candidate_k=20,\n    )\n\n    assert result.query == \"revenue\"\n    assert len(result.passages) > 0, \"Expected at least one passage for 'revenue'\"\n    for p in result.passages:\n        _assert_valid_passage(p)\n\n\n@pytest.mark.integration\n@pytest.mark.asyncio\nasync def test_hybrid_search_returns_ranked_passages(db_session, openai_client):\n    \"\"\"Full hybrid search (pgvector + full-text + RRF) returns top-k passages\n    in rank order for a realistic analyst query.\"\"\"\n    query = \"Apple iPhone revenue mix\"\n    vector = await _embed(openai_client, query)\n\n    result = await search_hybrid(\n        session=db_session,\n        query=query,\n        embed_vector=vector,\n        k=10,\n        candidate_k=50,\n    )\n\n    assert result.query == query\n    assert len(result.passages) > 0, \"Expected passages for Apple iPhone revenue query\"\n\n    ranks = [p.rank for p in result.passages]\n    assert ranks == list(range(1, len(ranks) + 1)), \"Passages must be ranked 1..N\"\n\n    for p in result.passages:\n        _assert_valid_passage(p)\n\n\n@pytest.mark.integration\n@pytest.mark.asyncio\nasync def test_hybrid_search_respects_k_limit(db_session, openai_client):\n    \"\"\"search_hybrid never returns more passages than requested k.\"\"\"\n    query = \"cloud computing operating income\"\n    vector = await _embed(openai_client, query)\n\n    result = await search_hybrid(\n        session=db_session,\n        query=query,\n        embed_vector=vector,\n        k=3,\n        candidate_k=20,\n    )\n\n    assert len(result.passages) <= 3\n\n\n@pytest.mark.integration\n@pytest.mark.asyncio\nasync def test_hybrid_search_nvidia_data_center(db_session, openai_client):\n    \"\"\"NVIDIA data center query should surface chunks from NVDA filings.\"\"\"\n    from sqlalchemy import text as sa_text\n    count = (await db_session.execute(sa_text(\"SELECT COUNT(*) FROM document_chunks\"))).scalar()\n    if not count:\n        pytest.skip(\"Corpus not ingested — run the ingest pipeline first\")\n\n    query = \"NVIDIA data center demand drivers supply constraints\"\n    vector = await _embed(openai_client, query)\n\n    result = await search_hybrid(\n        session=db_session,\n        query=query,\n        embed_vector=vector,\n        k=10,\n        candidate_k=50,\n    )\n\n    assert len(result.passages) > 0, \"Expected NVDA data center passages\"\n    texts = \" \".join(p.text for p in result.passages).lower()\n    assert any(term in texts for term in (\"data center\", \"nvidia\", \"gpu\")), (\n        \"Expected data center / NVDA / GPU terms in retrieved passages\"\n    )\n\n\n@pytest.mark.integration\n@pytest.mark.asyncio\nasync def test_empty_corpus_query_returns_result_object(db_session):\n    \"\"\"Even a query that matches nothing returns a RetrieverResult (not an exception).\"\"\"\n    result = await search_hybrid(\n        session=db_session,\n        query=\"xyzzy_impossible_query_abc123\",\n        embed_vector=None,\n        k=5,\n    )\n\n    assert result is not None\n    assert isinstance(result.passages, list)\n\n</content>\n</file>","success":true,"executionId":"38fd916c-c827-4a25-aa62-c5f293616cd6","_meta":{"kiro":{"agentMode":"vibe"}}}}
